# Node service port. Put this behind an HTTPS reverse proxy before connecting it to ChatGPT.
PORT=8794

# Use your own Supabase project and credentials. Never use service_role here.
TOY_SUPABASE_URL=https://your-project-ref.supabase.co
TOY_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
TOY_DEVICE_ID=YOUR_DEVICE_ID
TOY_CONTROLLER_TOKEN=YOUR_CONTROLLER_TOKEN
